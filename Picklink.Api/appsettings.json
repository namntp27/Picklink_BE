{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PicklinkDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "Picklink",
    "Audience": "Picklink.Web",
    "SecretKey": "CHANGE_ME_PICKLINK_SECRET_KEY_32_CHARS_MINIMUM",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Storage": {
    "UploadRoot": "wwwroot/uploads",
    "PublicBasePath": "/uploads",
    "MaxFileBytes": 5242880
  },
  "Seed": {
    "AdminEmail": "admin@picklink.local",
    "AdminFullName": "Picklink Admin",
    "AdminPassword": ""
  },
  "ExternalAuth": {
    "Google": {
      "ClientId": "",
      "TokenInfoEndpoint": "https://oauth2.googleapis.com/tokeninfo"
    },
    "Facebook": {
      "AppId": "",
      "AppSecret": "",
      "GraphBaseUrl": "https://graph.facebook.com"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
